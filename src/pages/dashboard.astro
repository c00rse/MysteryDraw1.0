---
import BaseLayout from "../layouts/BaseLayout.astro";
import { LogOut } from "../components/LogOut";
import UserProfile from "../components/UserProfile";
import { FriendList } from "../components/FriendList";
import Modal from "../components/Modal";
import NameChangeModal from "../components/NameChangeModal";
import ConfirmDeleteModal from "../components/ConfirmDeleteModal";
import NewDrawModal from "../components/NewDrawModal";
import DrawDetailsModal from "../components/DrawDetailsModal";
import DashboardDraws from "../components/DashboardDraws";
import AccentSwitch from "../components/AccentSwitch.astro";
import LanguageSwitch from "../components/LanguageSwitch.astro";

// Import komponentu Logo
import Logo from "../components/Logo.astro";
---

<BaseLayout>
    <Modal client:only="react" />
    <NameChangeModal client:only="react" />
    <ConfirmDeleteModal client:only="react" />
    <NewDrawModal client:only="react" />
    <DrawDetailsModal client:only="react" />

    <div id="dashboard-logo">
        <Logo size="2.5rem" />
    </div>

    <LanguageSwitch />

    <section>
        <div id="userProfile">
            <UserProfile client:only="react" />
        </div>

        <div id="sidePanel">
            <FriendList client:only="react" />
        </div>

        <DashboardDraws client:only="react" />
    </section>

    <AccentSwitch />

    <div id="logout">
        <LogOut client:only="react" />
    </div>
</BaseLayout>

<style>
    section {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 80vw;
        height: 80vh;
        display: grid;
        grid-template-columns: 1fr 3fr;
        grid-template-rows: 1fr 1fr 1fr 1fr;
    }

    section > div {
        background-color: var(--main-color);
        margin: 0.5rem;
        padding: 1rem;
        border-radius: 1rem;
    }

    #sidePanel {
        grid-column: 1 / 2;
        grid-row: 2 / 5;
    }

    #ongoing {
        grid-column: 2 / 3;
        grid-row: 1 / 3;
    }

    #finished {
        grid-column: 2 / 3;
        grid-row: 3 / 5;
    }

    #dashboard-logo {
        position: absolute;
        top: 1rem; /* Odstęp od góry */
        left: 50%; /* Środek poziomo */
        transform: translateX(-50%); /* Centrowanie */
        z-index: 10; /* Nad tłem, pod modalem */

        /* Zapobiega łamaniu tekstu na małych ekranach */
        white-space: nowrap;

        /* Opcjonalnie: cień pod tekstem dla lepszej czytelności */
        /* text-shadow: 0 2px 10px rgba(0,0,0,0.2); */
    }

    /* Na telefonach logo jeszcze troszkę mniejsze */
    @media (max-width: 600px) {
        #dashboard-logo {
            transform: translateX(-50%) scale(0.8); /* Skalujemy całość w dół */
            top: 0.8rem;
        }
    }

    #logout {
        position: absolute;
        bottom: 1.5rem;
        right: 4.5rem;
        z-index: 10;
    }
</style>
